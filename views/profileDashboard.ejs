<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Student Profile Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;700&display=swap" rel="stylesheet">
<style>
  body {
    font-family: 'Roboto', sans-serif;
    background: linear-gradient(to right, #eef2f3, #8e9eab);
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    padding: 20px;
  }

  .profile-card {
    background: #fff;
    border-radius: 20px;
    box-shadow: 0 15px 35px rgba(0,0,0,0.2);
    max-width: 500px;
    width: 100%;
    padding: 30px;
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .profile-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 25px 50px rgba(0,0,0,0.3);
  }

  .profile-card img {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    margin-bottom: 15px;
    border: 4px solid #2ecc71;
    transition: transform 0.3s ease;
  }

  .profile-card img:hover {
    transform: scale(1.1);
  }

  h2 {
    margin-bottom: 5px;
    font-size: 1.8em;
    color: #333;
  }

  p {
    margin-bottom: 25px;
    color: #666;
    font-size: 1em;
  }

  .pie-chart-container {
    position: relative;
    width: 300px;
    height: 300px;
    margin: 0 auto;
  }

  svg {
    transform: rotate(-90deg);
  }

  .legend {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-top: 20px;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.9em;
    font-weight: 500;
    color: #444;
  }

  .color-box {
    width: 15px;
    height: 15px;
    border-radius: 4px;
  }

  .red { background-color: #e74c3c; }
  .yellow { background-color: #f1c40f; }
  .green { background-color: #2ecc71; }

  .tooltip {
    position: absolute;
    padding: 6px 10px;
    background: rgba(0,0,0,0.7);
    color: #fff;
    font-size: 0.85em;
    border-radius: 6px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  /* Result styling */
  .correct { color: #2ecc71; font-weight: 600; }
  .wrong { color: #e74c3c; font-weight: 600; }

</style>
</head>
<body>

<div class="profile-card">
  <div style="text-align:center; margin-bottom:12px;"><img src="/logo.jpg" alt="App Logo" style="height:72px; object-fit:contain; border-radius:8px;"></div>
  <h2><%= student.name || 'Student' %></h2>
  <p><strong>Branch:</strong> <%= student.branch || 'N/A' %> &nbsp; | &nbsp; <strong>Language:</strong> <%= student.lang || 'N/A' %></p>

  <div style="margin-top:16px; display:flex; gap:14px; justify-content:center;">
    <div style="background:#f6f6f6; padding:12px 16px; border-radius:10px; text-align:center; color:#333;">
      <div style="font-size:22px; font-weight:700;"><%= student.marks %></div>
      <div style="font-size:12px;">Marks</div>
    </div>
    <div style="background:#f6f6f6; padding:12px 16px; border-radius:10px; text-align:center; color:#333;">
      <div style="font-size:22px; font-weight:700;"><%= student.attempted %>/<%= student.total %></div>
      <div style="font-size:12px;">Attempted / Total</div>
    </div>
    <div style="background:#f6f6f6; padding:12px 16px; border-radius:10px; text-align:center; color:#333;">
      <div style="font-size:18px; font-weight:700;"><%= student.result %></div>
      <div style="font-size:12px;">Result</div>
    </div>
  </div>

  <div style="margin-top:22px; text-align:left;">
    <h3 style="margin-bottom:8px;">Question Details</h3>
    <% if (Array.isArray(student.details) && student.details.length > 0) { %>
      <table style="width:100%; border-collapse:collapse;">
        <thead>
          <tr style="background:#efefef; color:#333;">
            <th style="padding:8px; text-align:left;">Question</th>
            <th style="padding:8px; width:120px;">Your Answer</th>
            <th style="padding:8px; width:120px;">Correct</th>
          </tr>
        </thead>
        <tbody>
          <% student.details.forEach(function(d){ %>
            <tr style="border-top:1px solid #eee;">
              <td style="padding:8px;"><%= d.question %></td>
              <td style="padding:8px;"><span class="<%= (d.selected===d.correct) ? 'correct' : 'wrong' %>"><%= d.selected || '—' %></span></td>
              <td style="padding:8px;"><%= d.correct %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } else { %>
      <p>No details available.</p>
    <% } %>
  </div>

  <div style="margin-top:18px; font-size:12px; color:#666; text-align:center;">Taken on: <%= (student.createdAt ? new Date(student.createdAt).toLocaleString() : 'N/A') %></div>
</div>

</body>
</html>
