<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Admin - Student Results</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <style>
        
        body {
            font-family: Inter, system-ui, Arial, sans-serif;
            padding: 24px;
            min-height: 100vh;
            margin: 0;
            background: linear-gradient(135deg, #e8eef3, #cfd9e4);
            background-attachment: fixed;
        }

        .card {
            box-shadow: 0 6px 18px rgba(20, 20, 50, 0.06);
            border: none;
            border-radius: 10px;
            background: rgba(255, 255, 255, 0.93);
            backdrop-filter: blur(4px);
        }

        table td, table th {
            vertical-align: middle;
        }

        h1, h5 {
            color: #333;
        }

        .btn-primary {
            background-color: #2c7a7b;
            border-color: #2c7a7b;
        }

        .btn-primary:hover {
            background-color: #225e5f;
            border-color: #225e5f;
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Header Section -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3">Student Results</h1>
            <a href="/exam?language=Java" class="btn btn-primary">Create New Exam</a>
        </div>

        <!-- Summary & Chart Row -->
        <div class="row mb-4">
            <div class="col-md-6 mb-3">
                <div class="card p-3">
                    <h5>Overall Summary</h5>
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Language</th>
                                    <th>Pass</th>
                                    <th>Fail</th>
                                    <th>Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (typeof statsObj !== 'undefined' && statsObj && Object.keys(statsObj).length) { %>
                                    <% Object.keys(statsObj).forEach(function(lang) { %>
                                        <tr>
                                            <td><%= lang %></td>
                                            <td><%= statsObj[lang].Pass || 0 %></td>
                                            <td><%= statsObj[lang].Fail || 0 %></td>
                                            <td><%= statsObj[lang].total || 0 %></td>
                                        </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr><td colspan="4">No statistics available</td></tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="col-md-6 mb-3">
                <div class="card p-3">
                    <h5>Pass/Fail by Subject (Chart)</h5>
                    <canvas id="subjectChart" height="160"></canvas>
                </div>
            </div>
        </div>

        <!-- Student List -->
        <div class="card p-3">
            <h5 class="mb-3">Student List</h5>
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Branch</th>
                            <th>Subject</th>
                            <th>Marks</th>
                            <th>Result</th>
                            <th>View</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (students && students.length) { %>
                            <% students.forEach(function(record) { %>
                                <tr>
                                    <td><%= record.name %></td>
                                    <td><%= record.branch %></td>
                                    <td><%= record.lang %></td>
                                    <td><%= record.marks %> / <%= record.total %></td>
                                    <td>
                                        <% if (record.result === 'Pass') { %>
                                            <span class="badge bg-success">Pass</span>
                                        <% } else { %>
                                            <span class="badge bg-danger">Fail</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <a href="/student/<%= record._id %>" class="btn btn-sm btn-outline-primary">Dashboard</a>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr><td colspan="6" class="text-center">No student records found</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    
    <script>
        (function(){
            const stats = JSON.parse('<%- JSON.stringify(typeof statsObj !== "undefined" ? statsObj : {}) %>');
            if (!stats || Object.keys(stats).length === 0) return;

            const langs = Object.keys(stats);
            const passData = langs.map(l => stats[l].Pass || 0);
            const failData = langs.map(l => stats[l].Fail || 0);

            const ctx = document.getElementById('subjectChart');
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: langs,
                    datasets: [
                        { label: 'Pass', data: passData, backgroundColor: 'rgba(40,167,69,0.8)' },
                        { label: 'Fail', data: failData, backgroundColor: 'rgba(220,53,69,0.8)' }
                    ]
                },
                options: {
                    responsive: true,
                    interaction: { mode: 'index', intersect: false },
                    plugins: { legend: { position: 'top' } },
                    scales: { y: { beginAtZero: true } }
                }
            });
        })();
    </script>

</body>
</html>
